generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TaskPriority {
  low
  medium
  high
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tasks        Task[]
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  completed   Boolean      @default(false)
  dueDate     DateTime?
  priority    TaskPriority?
  tags        Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([dueDate])
  @@index([completed])
}
